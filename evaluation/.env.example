# Sao chép file này thành .env và điền khóa.

# Khóa Gemini (giống biến trong be/.env): DeepEval dùng làm LLM judge cho các metric.
GEMINI_API_KEY=

# Một số phiên bản/toolchain đọc GOOGLE_API_KEY — script sẽ fallback sang GEMINI_API_KEY.
# GOOGLE_API_KEY=

# Model Gemini làm đánh giá (LLM-as-judge). Flash thường đủ và rẻ hơn Pro.
EVAL_GEMINI_MODEL=gemini-3.1-flash-lite
